# Backend URL — leave empty for local dev (uses Vite proxy, works on LAN/mobile too).
# Only set an explicit URL for production or when NOT using the Vite dev server.
# Production: https://api.yourdomain.com
VITE_BACKEND_URL=

# Demo mode — shows quick-fill buttons with demo credentials on the login page.
# NEVER set this to "true" in production. Leave unset or set to "false".
VITE_SHOW_DEMO=false
