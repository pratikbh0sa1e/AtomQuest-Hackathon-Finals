# Supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=

# JWT
JWT_SECRET=

# Metrics
METRICS_API_KEY=
METRICS_AUTH_DISABLED=false

# Agent / Supervisor credentials
# Credentials are stored in the 'agents' DB table — NOT in env vars.
# Run migrations/002_agents_table.sql to seed demo accounts.
# To add new users, INSERT into agents with a bcrypt-hashed password.

AI_SERVICE_URL=
AI_SERVICE_ENABLED=false

# Server
PORT=3001
FRONTEND_URL=http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5173,http://192.168.137.1:5173,http://10.102.117.202:5173
